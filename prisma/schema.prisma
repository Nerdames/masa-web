////////////////////////////////////
// GENERATOR & DATASOURCE
////////////////////////////////////

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

////////////////////////////////////
// ENUMS
////////////////////////////////////

enum Role {
  ADMIN
  MANAGER
  SALES
  INVENTORY
  CASHIER
  DEV
  AUDITOR // Added for Premium Audit access
}

enum PermissionAction {
  CREATE
  READ
  UPDATE
  DELETE
  VOID
  APPROVE
  EXPORT
}

enum TaxType {
  VAT
  SALES_TAX
  EXCISE
  NONE
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  BOGO // Buy One Get One
}

enum CustomerType {
  BUYER
  PARTNER
}

enum OrderStatus {
  DRAFT
  SUBMITTED
  FULFILLED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  VOIDED
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  MOBILE_MONEY
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum AccountType {
  CASH
  BANK
  MOBILE
  POS
}

enum TransactionType {
  PAYMENT
  REFUND
  TRANSFER
  ADJUSTMENT
}

enum StockMovementType {
  IN
  OUT
  ADJUST
  TRANSFER
}

enum StockTransferStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ExpenseType {
  OPERATIONAL
  CAPITAL
  MISC
}

enum NotificationType {
  SECURITY // Password/Email changes, Lock/Unlock
  INVENTORY // Stock added, Stock adjust, Price update
  APPROVAL // Approval required or Decision made
  SYSTEM // Table preferences, UI updates, Layout changes
  TRANSACTIONAL // Invoices, Sales, Refunds
  INFO // General announcements
}

enum CriticalAction {
  EMAIL_CHANGE
  PASSWORD_CHANGE
  PRICE_UPDATE
  STOCK_ADJUST
  STOCK_TRANSFER
  VOID_INVOICE
  USER_LOCK_UNLOCK
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum SaleStatus {
  COMPLETED
  CANCELLED
}

enum DraftSaleStatus {
  OPEN
  CHECKOUT
  ABANDONED
}

enum POSSessionStatus {
  OPEN
  CLOSED
}

enum POStatus {
  DRAFT
  ISSUED
  PARTIALLY_RECEIVED
  FULFILLED
  CANCELLED
}

enum GRNStatus {
  PENDING
  RECEIVED
  REJECTED
}

enum PreferenceScope {
  USER
  BRANCH
  ORGANIZATION
}

enum PreferenceCategory {
  UI
  LAYOUT
  TABLE
  NOTIFICATION
  SYSTEM
}

////////////////////////////////////
// ORGANIZATION & BRANCH
////////////////////////////////////

model Organization {
  id     String  @id @default(cuid())
  name   String
  active Boolean @default(true)

  ownerId String?
  owner   AuthorizedPersonnel? @relation("OrgOwner", fields: [ownerId], references: [id])

  approvalRequests ApprovalRequest[] @relation("OrgApprovals")

  // Existing relations...
  financeAccounts      FinanceAccount[]
  personnel            AuthorizedPersonnel[]  @relation("OrgMembers")
  branches             Branch[]
  products             Product[]
  customers            Customer[]
  orders               Order[]
  invoices             Invoice[]
  sales                Sale[]
  posSessions          POSSession[]           @relation("OrgPOSSessions")
  notifications        Notification[]
  activityLogs         ActivityLog[]
  branchProducts       BranchProduct[]
  customerTags         CustomerTag[]
  customerGroups       CustomerGroup[]
  customerSummaries    CustomerOrderSummary[]
  receipts             Receipt[]
  preferences          Preference[]
  notificationSettings NotificationSetting[]
  stockMovements       StockMovement[]
  categories           Category[]
  vendors              Vendor[]
  expenses             Expense[]
  draftSales           DraftSale[]            @relation("OrgDraftSales")
  stockTransfers       StockTransfer[]        @relation("OrgStockTransfers")
  purchaseOrders       PurchaseOrder[]        @relation("OrgPurchaseOrders")
  grns                 GoodsReceiptNote[]     @relation("OrgGRNs")

  // --- PREMIUM UPGRADE RELATIONS ---
  taxRates    TaxRate[]
  uoms        UnitOfMeasure[]
  refunds     Refund[]
  stockTakes  StockTake[]
  permissions Permission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model Branch {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  location       String?
  active         Boolean   @default(true)
  deletedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id])
  approvalRequests ApprovalRequest[] @relation("BranchApprovals")

  // Existing relations...
  financeAccounts   FinanceAccount[]
  personnel         AuthorizedPersonnel[]
  branchProducts    BranchProduct[]
  stockMoves        StockMovement[]        @relation("BranchStockMoves")
  orders            Order[]
  invoices          Invoice[]
  sales             Sale[]
  posSessions       POSSession[]           @relation("BranchPOSSessions")
  activityLogs      ActivityLog[]
  notifications     Notification[]
  branchAssignments BranchAssignment[]     @relation("BranchAssignments")
  customerSummaries CustomerOrderSummary[]
  receipts          Receipt[]
  preferences       Preference[]
  draftSales        DraftSale[]            @relation("BranchDraftSales")
  transfersFrom     StockTransfer[]        @relation("BranchTransfersFrom")
  transfersTo       StockTransfer[]        @relation("BranchTransfersTo")
  expenses          Expense[]
  purchaseOrders    PurchaseOrder[]        @relation("BranchPurchaseOrders") // Corrected based on your comment
  grns              GoodsReceiptNote[]     @relation("BranchGRNs") // Corrected based on your comment

  // --- PREMIUM UPGRADE RELATIONS ---
  refunds    Refund[]
  stockTakes StockTake[]

  @@index([organizationId])
  @@index([organizationId, deletedAt])
}

////////////////////////////////////
// AUTHORIZED PERSONNEL
////////////////////////////////////

model AuthorizedPersonnel {
  // ... (Keep all your existing scalar fields like email, password, lockReason, etc.)
  id        String    @id @default(cuid())
  name      String?
  email     String
  password  String
  staffCode String?
  role      Role      @default(CASHIER)
  disabled  Boolean   @default(false)
  deletedAt DateTime?
  lastLogin DateTime?

  organizationId String
  branchId       String?

  isOrgOwner             Boolean @default(false)
  pendingEmail           String?
  pendingPassword        String?
  isLocked               Boolean @default(false)
  lockReason             String?
  requiresPasswordChange Boolean @default(true)

  failedLoginAttempts Int       @default(0)
  lockoutUntil        DateTime?
  lastActivityAt      DateTime?

  lastLoginIp     String?
  lastLoginDevice String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ... (Keep all your existing relations)
  requestsCreated        ApprovalRequest[]       @relation("Requester")
  requestsApproved       ApprovalRequest[]       @relation("Approver")
  authAccounts           AuthAccount[]
  organization           Organization            @relation("OrgMembers", fields: [organizationId], references: [id])
  branch                 Branch?                 @relation(fields: [branchId], references: [id])
  posSessions            POSSession[]            @relation("CashierPOSSessions")
  branchAssignments      BranchAssignment[]
  orders                 Order[]                 @relation("SalespersonOrders")
  invoicesIssued         Invoice[]               @relation("IssuedInvoices")
  invoicesPaid           Payment[]               @relation("InvoicePaidBy")
  salesAttended          Sale[]                  @relation("AttendantSales")
  activityLogs           ActivityLog[]
  handledStockMoves      StockMovement[]         @relation("HandledStockMoves")
  financeAccounts        FinanceAccount[]
  sessions               Session[]
  ownedOrganizations     Organization[]          @relation("OrgOwner")
  receipts               Receipt[]               @relation("PersonnelReceipts")
  preferences            Preference[]
  notificationRecipients NotificationRecipient[]
  notificationSettings   NotificationSetting[]
  draftSales             DraftSale[]             @relation("CashierDraftSales")
  createdStockTransfers  StockTransfer[]         @relation("CreatedStockTransfers")
  approvedStockTransfers StockTransfer[]         @relation("ApprovedStockTransfers")
  productsCreated        Product[]               @relation("ProductCreatedBy")
  productsUpdated        Product[]               @relation("ProductUpdatedBy")
  categoriesCreated      Category[]              @relation("CategoryCreatedBy")
  categoriesUpdated      Category[]              @relation("CategoryUpdatedBy")
  vendorsCreated         Vendor[]                @relation("VendorCreatedBy")
  vendorsUpdated         Vendor[]                @relation("VendorUpdatedBy")
  customersCreated       Customer[]              @relation("CustomerCreatedBy")
  customersUpdated       Customer[]              @relation("CustomerUpdatedBy")
  invoicesUpdated        Invoice[]               @relation("InvoiceUpdatedBy")
  paymentsUpdated        Payment[]               @relation("PaymentUpdatedBy")
  stockMovementsUpdated  StockMovement[]         @relation("StockMovementUpdatedBy")
  receiptsUpdated        Receipt[]               @relation("ReceiptUpdatedBy")
  expensesCreated        Expense[]               @relation("ExpenseCreatedBy")
  expensesUpdated        Expense[]               @relation("ExpenseUpdatedBy")
  posCreated             PurchaseOrder[]         @relation("POCreatedBy")
  posApproved            PurchaseOrder[]         @relation("POApprovedBy")
  grnsReceived           GoodsReceiptNote[]      @relation("GRNReceivedBy")
  grnsApproved           GoodsReceiptNote[]      @relation("GRNApprovedBy")
  transactions           Transaction[]           @relation("HandledTransactions")

  // --- PREMIUM UPGRADE RELATIONS ---
  refundsProcessed   Refund[]            @relation("RefundProcessedBy")
  refundsApproved    Refund[]            @relation("RefundApprovedBy")
  stockTakesStarted  StockTake[]         @relation("StockTakeStartedBy")
  stockTakesApproved StockTake[]         @relation("StockTakeApprovedBy")
  reconciliationLogs ReconciliationLog[]

  @@unique([organizationId, email])
  @@unique([organizationId, staffCode])
  @@index([branchId])
  @@index([lastLogin])
  @@index([lastActivityAt])
  @@index([failedLoginAttempts])
  @@index([lockoutUntil])
  @@index([isLocked])
}

////////////////////////////////////
// APPROVAL SYSTEM
////////////////////////////////////

model ApprovalRequest {
  id             String  @id @default(cuid())
  organizationId String
  branchId       String?
  branch         Branch? @relation("BranchApprovals", fields: [branchId], references: [id])
  requesterId    String
  approverId     String?

  actionType    CriticalAction
  status        ApprovalStatus @default(PENDING)
  requiredRole  Role           @default(MANAGER)
  changes       Json
  rejectionNote String?

  targetType String?
  targetId   String?
  expense    Expense?

  expiresAt DateTime?
  appliedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  organization Organization         @relation("OrgApprovals", fields: [organizationId], references: [id])
  requester    AuthorizedPersonnel  @relation("Requester", fields: [requesterId], references: [id])
  approver     AuthorizedPersonnel? @relation("Approver", fields: [approverId], references: [id])

  stockMovements StockMovement[] @relation("ApprovalStockMoves")
  activityLogs   ActivityLog[]   @relation("ApprovalLogs")
  notifications  Notification[]

  @@index([organizationId, status])
  @@index([branchId, status])
  @@index([actionType])
}

model BranchAssignment {
  id          String  @id @default(cuid())
  personnelId String
  branchId    String
  role        Role
  isPrimary   Boolean @default(false)

  personnel AuthorizedPersonnel @relation(fields: [personnelId], references: [id])
  branch    Branch              @relation("BranchAssignments", fields: [branchId], references: [id])

  @@unique([personnelId, branchId])
  // This unique index prevents a user from having two primary branches
  @@unique([personnelId, isPrimary], map: "one_primary_branch_per_personnel")
  @@index([personnelId])
  @@index([branchId])
}

// NEW: Granular Permissions for RBAC/ABAC
model Permission {
  id             String           @id @default(cuid())
  role           Role
  action         PermissionAction
  resource       String // e.g., "INVOICE", "STOCK_ADJUST"
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, role, action, resource])
}

////////////////////////////////////
// PREMIUM ENGINES (UoM, Tax, Returns, Audits)
////////////////////////////////////

model UnitOfMeasure {
  id             String   @id @default(cuid())
  organizationId String
  name           String // e.g., "Kilogram", "Piece"
  abbreviation   String // e.g., "kg", "pcs"
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  products       Product[]
  branchProducts BranchProduct[]

  @@unique([organizationId, abbreviation])
  @@index([organizationId])
}

model TaxRate {
  id             String   @id @default(cuid())
  organizationId String
  name           String // e.g., "VAT 7.5%"
  rate           Decimal  @db.Decimal(5, 2)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  orderItems   OrderItem[]
  sales        Sale[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Refund {
  id             String  @id @default(cuid())
  organizationId String
  branchId       String
  invoiceId      String
  refundNumber   String?

  totalRefunded Decimal        @db.Decimal(18, 2)
  reason        String?
  status        ApprovalStatus @default(PENDING)

  processedById String
  approvedById  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id])
  branch       Branch               @relation(fields: [branchId], references: [id])
  invoice      Invoice              @relation(fields: [invoiceId], references: [id])
  processedBy  AuthorizedPersonnel  @relation("RefundProcessedBy", fields: [processedById], references: [id])
  approvedBy   AuthorizedPersonnel? @relation("RefundApprovedBy", fields: [approvedById], references: [id])

  items       RefundItem[]
  transaction Transaction?

  @@unique([organizationId, refundNumber])
  @@index([organizationId, branchId])
  @@index([invoiceId])
  @@index([status])
}

model RefundItem {
  id              String @id @default(cuid())
  refundId        String
  saleId          String
  branchProductId String

  quantity     Int
  refundAmount Decimal @db.Decimal(18, 2)
  restocked    Boolean @default(true) // Tracks if item went back to inventory

  refund         Refund          @relation(fields: [refundId], references: [id], onDelete: Cascade)
  sale           Sale            @relation(fields: [saleId], references: [id])
  branchProduct  BranchProduct   @relation(fields: [branchProductId], references: [id])
  stockMovements StockMovement[]

  @@index([refundId])
  @@index([saleId])
  @@index([branchProductId])
}

model StockTake {
  id             String         @id @default(cuid())
  organizationId String
  branchId       String
  status         ApprovalStatus @default(PENDING)
  notes          String?

  startedById  String
  approvedById String?

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  organization Organization         @relation(fields: [organizationId], references: [id])
  branch       Branch               @relation(fields: [branchId], references: [id])
  startedBy    AuthorizedPersonnel  @relation("StockTakeStartedBy", fields: [startedById], references: [id])
  approvedBy   AuthorizedPersonnel? @relation("StockTakeApprovedBy", fields: [approvedById], references: [id])

  items StockTakeItem[]

  @@index([organizationId, branchId])
  @@index([status])
}

model StockTakeItem {
  id              String @id @default(cuid())
  stockTakeId     String
  branchProductId String

  expectedStock  Int
  actualStock    Int
  discrepancy    Int // Auto-calculated (actual - expected)
  unitCost       Decimal @db.Decimal(18, 2)
  totalLossValue Decimal @default(0) @db.Decimal(18, 2)

  stockTake      StockTake       @relation(fields: [stockTakeId], references: [id], onDelete: Cascade)
  branchProduct  BranchProduct   @relation(fields: [branchProductId], references: [id])
  stockMovements StockMovement[]

  @@index([stockTakeId])
  @@index([branchProductId])
}

////////////////////////////////////
// CUSTOMERS
////////////////////////////////////

model Customer {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  email          String?
  phone          String?
  address        String?
  type           CustomerType

  totalOrders Int       @default(0)
  totalSpent  Decimal   @default(0) @db.Decimal(18, 2)
  deletedAt   DateTime?

  createdById String?
  updatedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id])
  createdBy    AuthorizedPersonnel? @relation("CustomerCreatedBy", fields: [createdById], references: [id])
  updatedBy    AuthorizedPersonnel? @relation("CustomerUpdatedBy", fields: [updatedById], references: [id])

  orders            Order[]
  invoices          Invoice[]
  sales             Sale[]                 @relation("CustomerSales")
  tags              CustomerTag[]
  groups            CustomerGroup[]        @relation("CustomerGroups")
  customerSummaries CustomerOrderSummary[]

  @@index([organizationId])
  @@index([organizationId, deletedAt])
}

model CustomerTag {
  id             String    @id @default(cuid())
  organizationId String
  customerId     String
  name           String
  deletedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])

  @@unique([customerId, name])
  @@index([organizationId])
  @@index([customerId])
}

model CustomerGroup {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  description    String?
  deletedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  customers    Customer[]   @relation("CustomerGroups")

  @@unique([organizationId, name])
  @@index([organizationId])
}

////////////////////////////////////
// PRODUCTS & INVENTORY
////////////////////////////////////

model Product {
  id             String  @id @default(cuid())
  organizationId String
  name           String
  sku            String
  barcode        String?
  description    String?
  categoryId     String?

  // --- PREMIUM UPGRADES ---
  baseCostPrice Decimal @default(0) @db.Decimal(18, 2) // Master financial reference
  uomId         String? // Replaces the raw "unit" string

  costPrice Decimal   @db.Decimal(18, 2)
  currency  String    @default("NGN")
  deletedAt DateTime?

  createdById String?
  updatedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id])
  category     Category?            @relation(fields: [categoryId], references: [id])
  uom          UnitOfMeasure?       @relation(fields: [uomId], references: [id])
  createdBy    AuthorizedPersonnel? @relation("ProductCreatedBy", fields: [createdById], references: [id])
  updatedBy    AuthorizedPersonnel? @relation("ProductUpdatedBy", fields: [updatedById], references: [id])

  branches           BranchProduct[]
  orderItems         OrderItem[]         @relation("ProductOrderItems")
  sales              Sale[]              @relation("ProductSales")
  draftSaleItems     DraftSaleItem[]
  stockTransferItems StockTransferItem[]
  stockMovements     StockMovement[]
  poItems            PurchaseOrderItem[]
  grnItems           GoodsReceiptItem[]

  @@unique([organizationId, sku])
  @@unique([organizationId, barcode])
  @@index([organizationId])
  @@index([organizationId, deletedAt])
  @@index([categoryId])
  @@index([uomId])
}

model BranchProduct {
  id             String @id @default(cuid())
  organizationId String
  branchId       String
  productId      String

  stock           Int       @default(0)
  stockVersion    Int       @default(1)
  reorderLevel    Int       @default(0)
  lastSoldAt      DateTime?
  lastRestockedAt DateTime?
  safetyStock     Int?      @default(0)

  // --- PREMIUM UPGRADES ---
  uomId String? // Inherits or overrides product UoM

  sellingPrice Decimal?  @db.Decimal(18, 2)
  vendorId     String?
  costPrice    Decimal?  @db.Decimal(18, 2)
  deletedAt    DateTime?

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product      Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  vendor       Vendor?        @relation(fields: [vendorId], references: [id])
  uom          UnitOfMeasure? @relation(fields: [uomId], references: [id])

  orderItems         OrderItem[]         @relation("BranchProductOrderItems")
  sales              Sale[]              @relation("BranchProductSales")
  stockMoves         StockMovement[]     @relation("BranchProductStockMoves")
  receipts           Receipt[]
  draftSaleItems     DraftSaleItem[]
  stockTransferItems StockTransferItem[]
  grnItems           GoodsReceiptItem[]

  // New Audit & Return hooks
  refundItems    RefundItem[]
  stockTakeItems StockTakeItem[]

  @@unique([branchId, productId])
  @@index([organizationId])
  @@index([organizationId, deletedAt])
  @@index([branchId])
  @@index([branchId, deletedAt])
  @@index([productId])
  @@index([vendorId])
  @@index([stock])
  @@index([reorderLevel])
  @@index([deletedAt])
  @@index([uomId])
}

////////////////////////////////////
// CATEGORIES, VENDORS
////////////////////////////////////

model Category {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  description    String?
  deletedAt      DateTime?

  createdById String?
  updatedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id])
  createdBy    AuthorizedPersonnel? @relation("CategoryCreatedBy", fields: [createdById], references: [id])
  updatedBy    AuthorizedPersonnel? @relation("CategoryUpdatedBy", fields: [updatedById], references: [id])
  products     Product[]
  expenses     Expense[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

////////////////////////////////////
// PROCUREMENT & RECEIVING
////////////////////////////////////

model PurchaseOrder {
  id             String @id @default(cuid())
  organizationId String
  branchId       String
  vendorId       String
  poNumber       String

  status       POStatus  @default(DRAFT)
  totalAmount  Decimal   @db.Decimal(18, 2)
  currency     String    @default("NGN")
  expectedDate DateTime?
  notes        String?
  deletedAt    DateTime?

  createdById  String
  approvedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization         @relation("OrgPurchaseOrders", fields: [organizationId], references: [id])
  branch       Branch               @relation("BranchPurchaseOrders", fields: [branchId], references: [id])
  vendor       Vendor               @relation("VendorPurchaseOrders", fields: [vendorId], references: [id])
  createdBy    AuthorizedPersonnel  @relation("POCreatedBy", fields: [createdById], references: [id])
  approvedBy   AuthorizedPersonnel? @relation("POApprovedBy", fields: [approvedById], references: [id])

  items PurchaseOrderItem[]
  grns  GoodsReceiptNote[]

  @@unique([organizationId, poNumber])
  @@index([organizationId, branchId])
  @@index([vendorId])
  @@index([status])
}

model PurchaseOrderItem {
  id              String @id @default(cuid())
  purchaseOrderId String
  productId       String

  quantityOrdered  Int
  quantityReceived Int     @default(0)
  unitCost         Decimal @db.Decimal(18, 2)
  totalCost        Decimal @db.Decimal(18, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrder PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product            @relation(fields: [productId], references: [id])
  grnItems      GoodsReceiptItem[]

  @@index([purchaseOrderId])
  @@index([productId])
}

model GoodsReceiptNote {
  id              String  @id @default(cuid())
  organizationId  String
  branchId        String
  purchaseOrderId String?
  vendorId        String
  grnNumber       String

  status     GRNStatus @default(PENDING)
  receivedAt DateTime  @default(now())
  notes      String?

  receivedById String
  approvedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization  Organization         @relation("OrgGRNs", fields: [organizationId], references: [id])
  branch        Branch               @relation("BranchGRNs", fields: [branchId], references: [id])
  purchaseOrder PurchaseOrder?       @relation(fields: [purchaseOrderId], references: [id])
  vendor        Vendor               @relation("VendorGRNs", fields: [vendorId], references: [id])
  receivedBy    AuthorizedPersonnel  @relation("GRNReceivedBy", fields: [receivedById], references: [id])
  approvedBy    AuthorizedPersonnel? @relation("GRNApprovedBy", fields: [approvedById], references: [id])

  items          GoodsReceiptItem[]
  stockMovements StockMovement[]

  @@unique([organizationId, grnNumber])
  @@index([purchaseOrderId])
  @@index([vendorId])
}

model GoodsReceiptItem {
  id              String  @id @default(cuid())
  grnId           String
  poItemId        String?
  productId       String
  branchProductId String

  quantityAccepted Int
  quantityRejected Int     @default(0)
  unitCost         Decimal @db.Decimal(18, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  grn           GoodsReceiptNote   @relation(fields: [grnId], references: [id], onDelete: Cascade)
  poItem        PurchaseOrderItem? @relation(fields: [poItemId], references: [id])
  product       Product            @relation(fields: [productId], references: [id])
  branchProduct BranchProduct      @relation(fields: [branchProductId], references: [id])

  @@index([grnId])
  @@index([branchProductId])
}

model Vendor {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  email          String?
  phone          String?
  address        String?
  deletedAt      DateTime?

  createdById String?
  updatedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrders PurchaseOrder[]      @relation("VendorPurchaseOrders")
  grns           GoodsReceiptNote[]   @relation("VendorGRNs")
  organization   Organization         @relation(fields: [organizationId], references: [id])
  createdBy      AuthorizedPersonnel? @relation("VendorCreatedBy", fields: [createdById], references: [id])
  updatedBy      AuthorizedPersonnel? @relation("VendorUpdatedBy", fields: [updatedById], references: [id])
  branchProducts BranchProduct[]
  expenses       Expense[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([organizationId, deletedAt])
}

////////////////////////////////////
// ORDERS & INVOICES
////////////////////////////////////

model Order {
  id             String  @id @default(cuid())
  organizationId String
  branchId       String
  salespersonId  String
  customerId     String?
  orderNumber    String?

  total     Decimal     @db.Decimal(18, 2)
  currency  String      @default("NGN")
  status    OrderStatus @default(DRAFT)
  notes     String?
  expiresAt DateTime?
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items      OrderItem[]
  invoice    Invoice?
  invoicedAt DateTime?

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  salesperson  AuthorizedPersonnel @relation("SalespersonOrders", fields: [salespersonId], references: [id])
  customer     Customer?           @relation(fields: [customerId], references: [id])

  @@unique([organizationId, orderNumber])
  @@index([organizationId, branchId, status])
  @@index([organizationId, deletedAt])
  @@index([branchId, createdAt])
  @@index([salespersonId])
  @@index([customerId])
}

model OrderItem {
  id              String @id @default(cuid())
  orderId         String
  branchProductId String
  productId       String

  quantity  Int
  unitPrice Decimal  @db.Decimal(18, 2)
  total     Decimal  @db.Decimal(18, 2)
  discount  Decimal? @default(0) @db.Decimal(18, 2)
  tax       Decimal? @default(0) @db.Decimal(18, 2)
  taxRateId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order         Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  branchProduct BranchProduct   @relation("BranchProductOrderItems", fields: [branchProductId], references: [id])
  product       Product         @relation("ProductOrderItems", fields: [productId], references: [id])
  taxRate       TaxRate?        @relation(fields: [taxRateId], references: [id])
  stockMoves    StockMovement[]

  @@index([orderId])
  @@index([branchProductId])
  @@index([productId])
}

model Invoice {
  // ... (Keep existing scalars)
  id             String  @id @default(cuid())
  organizationId String
  branchId       String
  orderId        String  @unique
  invoiceNumber  String?

  issuedById  String
  updatedById String?
  customerId  String?

  subtotal   Decimal?      @db.Decimal(18, 2)
  total      Decimal?      @db.Decimal(18, 2)
  discount   Decimal?      @default(0) @db.Decimal(18, 2)
  tax        Decimal?      @default(0) @db.Decimal(18, 2)
  paidAmount Decimal?      @default(0) @db.Decimal(18, 2)
  balance    Decimal?      @db.Decimal(18, 2)
  currency   String        @default("NGN")
  status     InvoiceStatus @default(DRAFT)
  deletedAt  DateTime?

  issuedAt DateTime  @default(now())
  dueDate  DateTime?
  lockedAt DateTime?

  payments Payment[]
  sales    Sale[]
  receipts Receipt[]

  // --- PREMIUM UPGRADES ---
  refunds Refund[]

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch               @relation(fields: [branchId], references: [id])
  order        Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  issuedBy     AuthorizedPersonnel  @relation("IssuedInvoices", fields: [issuedById], references: [id])
  updatedBy    AuthorizedPersonnel? @relation("InvoiceUpdatedBy", fields: [updatedById], references: [id])
  customer     Customer?            @relation(fields: [customerId], references: [id])
  checkHash    String?

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId, branchId, status])
  @@index([issuedAt])
  @@index([organizationId, deletedAt])
}

model Payment {
  id             String       @id @default(cuid())
  organizationId String
  invoiceId      String
  cashierId      String
  updatedById    String? // For audit/compliance
  receiptId      String?
  transaction    Transaction?

  method    PaymentMethod
  amount    Decimal       @db.Decimal(18, 2)
  currency  String        @default("NGN")
  status    PaymentStatus @default(COMPLETED)
  deletedAt DateTime?

  reference  String?
  receivedAt DateTime @default(now())

  // Relations
  invoice   Invoice              @relation(fields: [invoiceId], references: [id])
  cashier   AuthorizedPersonnel  @relation("InvoicePaidBy", fields: [cashierId], references: [id])
  updatedBy AuthorizedPersonnel? @relation("PaymentUpdatedBy", fields: [updatedById], references: [id])
  receipt   Receipt?             @relation("PaymentReceipt", fields: [receiptId], references: [id])

  @@index([invoiceId])
  @@index([cashierId])
  @@index([updatedById])
  @@index([receiptId])
  @@index([method])
  @@index([status])
  @@index([receivedAt])
  @@index([currency])
  @@index([reference])
}

////////////////////////////////////
// DRAFT SALES & SALES
////////////////////////////////////

model DraftSale {
  id             String  @id @default(cuid())
  organizationId String
  branchId       String
  cashierId      String
  posSessionId   String?

  status    DraftSaleStatus @default(OPEN)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items DraftSaleItem[]

  organization Organization        @relation("OrgDraftSales", fields: [organizationId], references: [id])
  branch       Branch              @relation("BranchDraftSales", fields: [branchId], references: [id])
  cashier      AuthorizedPersonnel @relation("CashierDraftSales", fields: [cashierId], references: [id])
  posSession   POSSession?         @relation("POSSessionDraftSales", fields: [posSessionId], references: [id])

  @@index([cashierId])
  @@index([cashierId, posSessionId])
}

model DraftSaleItem {
  id              String @id @default(cuid())
  draftSaleId     String
  branchProductId String
  productId       String

  quantity  Int
  unitPrice Decimal @db.Decimal(18, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  draftSale     DraftSale     @relation(fields: [draftSaleId], references: [id], onDelete: Cascade)
  branchProduct BranchProduct @relation(fields: [branchProductId], references: [id])
  product       Product       @relation(fields: [productId], references: [id])

  @@index([draftSaleId])
  @@index([branchProductId])
  @@index([productId])
}

model Sale {
  // ... (Keep existing scalars)
  id              String @id @default(cuid())
  organizationId  String
  invoiceId       String
  branchProductId String
  productId       String
  branchId        String

  quantity  Int
  unitPrice Decimal    @db.Decimal(18, 2)
  total     Decimal    @db.Decimal(18, 2)
  currency  String     @default("NGN")
  status    SaleStatus @default(COMPLETED)
  deletedAt DateTime?

  cashierId  String
  customerId String?

  // --- PREMIUM UPGRADES: Linked Tax ---
  taxRateId String?
  tax       Decimal? @default(0) @db.Decimal(18, 2)
  discount  Decimal? @default(0) @db.Decimal(18, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  receipts   Receipt[]
  stockMoves StockMovement[]

  // Audit & Returns hooks
  refundItems RefundItem[]

  organization  Organization        @relation(fields: [organizationId], references: [id])
  invoice       Invoice             @relation(fields: [invoiceId], references: [id])
  branchProduct BranchProduct       @relation("BranchProductSales", fields: [branchProductId], references: [id])
  product       Product             @relation("ProductSales", fields: [productId], references: [id])
  branch        Branch              @relation(fields: [branchId], references: [id])
  attendant     AuthorizedPersonnel @relation("AttendantSales", fields: [cashierId], references: [id])
  customer      Customer?           @relation("CustomerSales", fields: [customerId], references: [id])
  taxRate       TaxRate?            @relation(fields: [taxRateId], references: [id])

  @@unique([invoiceId, branchProductId])
  @@index([organizationId, branchId])
  @@index([organizationId, deletedAt])
  @@index([organizationId, createdAt])
  @@index([invoiceId])
  @@index([productId])
  @@index([branchProductId])
  @@index([cashierId])
  @@index([customerId])
  @@index([createdAt])
  @@index([branchId, createdAt])
  @@index([cashierId, createdAt])
  @@index([taxRateId])
}

////////////////////////////////////
// STOCK MOVEMENTS
////////////////////////////////////

model StockMovement {
  id              String            @id @default(cuid())
  organizationId  String
  branchId        String
  branchProductId String
  productId       String
  type            StockMovementType
  quantity        Int
  unitCost        Decimal           @db.Decimal(18, 2)
  totalCost       Decimal           @db.Decimal(18, 2)
  reason          String?

  runningBalance Int
  previousHash   String?
  hash           String?

  approvedAt  DateTime?
  approvalId  String?
  handledById String?
  updatedById String?
  deletedAt   DateTime?

  // --- POLYMORPHIC TRACEABILITY (PREMIUM UPGRADES) ---
  saleId              String?
  orderItemId         String?
  stockTransferItemId String?
  grnId               String?
  refundItemId        String? // NEW: Trace back to customer returns
  stockTakeItemId     String? // NEW: Trace back to audit adjustments

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization  Organization         @relation(fields: [organizationId], references: [id])
  branch        Branch               @relation("BranchStockMoves", fields: [branchId], references: [id])
  branchProduct BranchProduct        @relation("BranchProductStockMoves", fields: [branchProductId], references: [id])
  product       Product              @relation(fields: [productId], references: [id])
  approval      ApprovalRequest?     @relation("ApprovalStockMoves", fields: [approvalId], references: [id])
  handledBy     AuthorizedPersonnel? @relation("HandledStockMoves", fields: [handledById], references: [id])
  updatedBy     AuthorizedPersonnel? @relation("StockMovementUpdatedBy", fields: [updatedById], references: [id])

  sale              Sale?              @relation(fields: [saleId], references: [id])
  orderItem         OrderItem?         @relation(fields: [orderItemId], references: [id])
  stockTransferItem StockTransferItem? @relation(fields: [stockTransferItemId], references: [id])
  grn               GoodsReceiptNote?  @relation(fields: [grnId], references: [id])
  refundItem        RefundItem?        @relation(fields: [refundItemId], references: [id])
  stockTakeItem     StockTakeItem?     @relation(fields: [stockTakeItemId], references: [id])

  @@index([organizationId])
  @@index([organizationId, deletedAt])
  @@index([branchId])
  @@index([branchProductId])
  @@index([productId])
  @@index([type])
  @@index([approvedAt])
  @@index([deletedAt])
  @@index([branchProductId, type])
  @@index([branchProductId, createdAt])
  @@index([updatedById])
  @@index([grnId])
  @@index([refundItemId])
  @@index([stockTakeItemId])
}

////////////////////////////////////
// STOCK TRANSFERS
////////////////////////////////////

model StockTransfer {
  id             String              @id @default(cuid())
  organizationId String
  fromBranchId   String
  toBranchId     String
  status         StockTransferStatus
  createdById    String
  approvedById   String?
  approvedAt     DateTime?
  deletedAt      DateTime?
  transferNumber String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization         @relation("OrgStockTransfers", fields: [organizationId], references: [id])
  fromBranch   Branch               @relation("BranchTransfersFrom", fields: [fromBranchId], references: [id])
  toBranch     Branch               @relation("BranchTransfersTo", fields: [toBranchId], references: [id])
  createdBy    AuthorizedPersonnel  @relation("CreatedStockTransfers", fields: [createdById], references: [id])
  approvedBy   AuthorizedPersonnel? @relation("ApprovedStockTransfers", fields: [approvedById], references: [id])

  items StockTransferItem[]

  @@unique([organizationId, transferNumber])
  @@index([organizationId])
  @@index([fromBranchId])
  @@index([toBranchId])
  @@index([status])
  @@index([deletedAt])
}

model StockTransferItem {
  id              String    @id @default(cuid())
  stockTransferId String
  branchProductId String
  productId       String
  quantity        Int
  deletedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stockTransfer StockTransfer   @relation(fields: [stockTransferId], references: [id], onDelete: Cascade)
  branchProduct BranchProduct   @relation(fields: [branchProductId], references: [id])
  product       Product         @relation(fields: [productId], references: [id])
  stockMoves    StockMovement[]

  @@index([stockTransferId])
  @@index([branchProductId])
  @@index([productId])
}

////////////////////////////////////
// RECEIPTS & TRANSACTIONS
////////////////////////////////////

model Receipt {
  id              String  @id @default(cuid())
  organizationId  String
  branchId        String
  personnelId     String // now required
  saleId          String?
  invoiceId       String?
  branchProductId String?
  posSessionId    String?
  receiptNumber   String?

  amount    Decimal   @db.Decimal(18, 2)
  currency  String    @default("NGN")
  deletedAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedById String? // optional audit field

  // Relations
  organization  Organization         @relation(fields: [organizationId], references: [id])
  branch        Branch               @relation(fields: [branchId], references: [id])
  personnel     AuthorizedPersonnel  @relation("PersonnelReceipts", fields: [personnelId], references: [id])
  updatedBy     AuthorizedPersonnel? @relation("ReceiptUpdatedBy", fields: [updatedById], references: [id])
  sale          Sale?                @relation(fields: [saleId], references: [id])
  invoice       Invoice?             @relation(fields: [invoiceId], references: [id])
  branchProduct BranchProduct?       @relation(fields: [branchProductId], references: [id])
  posSession    POSSession?          @relation("POSSessionReceipts", fields: [posSessionId], references: [id])
  payments      Payment[]            @relation("PaymentReceipt")

  @@unique([organizationId, receiptNumber])
  // Indexes
  @@index([organizationId, branchId])
  @@index([saleId])
  @@index([invoiceId])
  @@index([branchProductId])
  @@index([deletedAt])
  @@index([updatedById])
}

////////////////////////////////////
// POS SESSION 
////////////////////////////////////

model POSSession {
  id             String @id @default(cuid())
  organizationId String
  branchId       String
  cashierId      String

  openedAt       DateTime         @default(now())
  closedAt       DateTime?
  openingBalance Decimal          @db.Decimal(18, 2)
  closingBalance Decimal?         @db.Decimal(18, 2)
  status         POSSessionStatus @default(OPEN)

  organization Organization        @relation("OrgPOSSessions", fields: [organizationId], references: [id])
  branch       Branch              @relation("BranchPOSSessions", fields: [branchId], references: [id])
  cashier      AuthorizedPersonnel @relation("CashierPOSSessions", fields: [cashierId], references: [id])

  receipts   Receipt[]   @relation("POSSessionReceipts")
  draftSales DraftSale[] @relation("POSSessionDraftSales")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId])
  @@index([cashierId])
  @@index([cashierId, status])
  @@index([status])
}

////////////////////////////////////
// ACTIVITY LOGS
////////////////////////////////////

model ActivityLog {
  id             String    @id @default(cuid())
  organizationId String
  branchId       String?
  personnelId    String?
  action         String
  critical       Boolean   @default(false)
  ipAddress      String?
  deviceInfo     String?
  metadata       Json?
  deletedAt      DateTime?
  approvalId     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization  Organization         @relation(fields: [organizationId], references: [id])
  branch        Branch?              @relation(fields: [branchId], references: [id])
  personnel     AuthorizedPersonnel? @relation(fields: [personnelId], references: [id])
  approval      ApprovalRequest?     @relation("ApprovalLogs", fields: [approvalId], references: [id])
  notifications Notification[]

  @@index([organizationId, branchId])
  @@index([personnelId])
  @@index([action])
  @@index([critical])
  @@index([createdAt])
  @@index([deletedAt])
}

////////////////////////////////////
// NOTIFICATIONS
////////////////////////////////////

model Notification {
  id             String           @id @default(cuid())
  organizationId String
  branchId       String?
  type           NotificationType

  // High Efficiency: Link directly to the triggering action/log
  actionTrigger CriticalAction? // Points to your existing CriticalAction enum
  activityLogId String? // The source ActivityLog for details

  title      String
  message    String
  approvalId String?
  deletedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization            @relation(fields: [organizationId], references: [id])
  branch       Branch?                 @relation(fields: [branchId], references: [id])
  approval     ApprovalRequest?        @relation(fields: [approvalId], references: [id])
  activity     ActivityLog?            @relation(fields: [activityLogId], references: [id])
  recipients   NotificationRecipient[]

  @@index([organizationId, branchId])
  @@index([type])
  @@index([actionTrigger])
  @@index([deletedAt])
}

model NotificationRecipient {
  id             String  @id @default(cuid())
  notificationId String
  personnelId    String
  read           Boolean @default(false)

  // Helpful for cleanup or prioritizing recent push notifications
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notification Notification        @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  personnel    AuthorizedPersonnel @relation(fields: [personnelId], references: [id], onDelete: Cascade)

  @@unique([notificationId, personnelId])
  @@index([personnelId])
  @@index([read])
}

model NotificationSetting {
  id               String           @id @default(cuid())
  organizationId   String
  personnelId      String?
  notificationType NotificationType

  // Delivery Channels: Makes push logic very efficient
  inAppEnabled Boolean @default(true)
  pushEnabled  Boolean @default(false)
  emailEnabled Boolean @default(false)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id])
  personnel    AuthorizedPersonnel? @relation(fields: [personnelId], references: [id])

  @@unique([organizationId, personnelId, notificationType])
  @@index([organizationId])
  @@index([personnelId])
}

////////////////////////////////////
// PREFERENCES
////////////////////////////////////

model Preference {
  id             String             @id @default(cuid())
  scope          PreferenceScope
  category       PreferenceCategory
  key            String
  value          Json
  organizationId String
  branchId       String?
  personnelId    String?
  target         String?
  isLocked       Boolean            @default(false)
  deletedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id])
  branch       Branch?              @relation(fields: [branchId], references: [id])
  personnel    AuthorizedPersonnel? @relation(fields: [personnelId], references: [id])

  @@unique([scope, category, key, organizationId, branchId, personnelId, target])
  @@index([organizationId])
  @@index([branchId])
  @@index([personnelId])
  @@index([scope])
  @@index([category])
  @@index([key])
  @@index([target])
  @@index([deletedAt])
}

////////////////////////////////////
// ACCOUNTS & TRANSACTIONS
////////////////////////////////////

model FinanceAccount {
  id             String      @id @default(cuid())
  organizationId String
  branchId       String?
  personnelId    String?
  name           String
  balance        Decimal     @default(0) @db.Decimal(18, 2)
  version        Int         @default(1) // Optimized concurrency control
  currency       String      @default("NGN")
  type           AccountType
  isFrozen       Boolean     @default(false) // Emergency lock
  deletedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id])
  branch       Branch?              @relation(fields: [branchId], references: [id])
  personnel    AuthorizedPersonnel? @relation(fields: [personnelId], references: [id])

  transactions       Transaction[]
  reconciliationLogs ReconciliationLog[]

  @@unique([organizationId, branchId, name])
  @@index([organizationId])
  @@index([branchId])
  @@index([personnelId])
  @@index([deletedAt])
}

model Transaction {
  id        String          @id @default(cuid())
  accountId String
  type      TransactionType
  amount    Decimal         @db.Decimal(18, 2)
  currency  String          @default("NGN")

  // --- PREMIUM LEDGER INTEGRITY ---
  runningBalance Decimal @db.Decimal(18, 2)
  previousHash   String?
  hash           String?

  // --- ORIGIN TRACEABILITY ---
  paymentId   String? @unique
  expenseId   String? @unique
  transferId  String?
  handledById String?
  refundId    String? @unique // PREMIUM UPGRADE: Financial trace for cash returns

  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // --- RELATIONS ---
  account FinanceAccount @relation(fields: [accountId], references: [id])
  payment Payment?       @relation(fields: [paymentId], references: [id])

  // FIXED: Added named relation "TransactionToExpense" to resolve 1:1 ambiguity
  expense Expense? @relation("TransactionToExpense", fields: [expenseId], references: [id])

  // FIXED: Matches the @relation("HandledTransactions") now in AuthorizedPersonnel
  handledBy AuthorizedPersonnel? @relation("HandledTransactions", fields: [handledById], references: [id])

  refund Refund? @relation(fields: [refundId], references: [id])

  // --- INDEXING ---
  @@index([accountId, createdAt])
  @@index([type])
  @@index([paymentId])
  @@index([expenseId])
  @@index([refundId])
}

////////////////////////////////////
// EXPENSES
////////////////////////////////////

model Expense {
  id             String  @id @default(cuid())
  organizationId String
  branchId       String
  categoryId     String // Categorized for audit (e.g., Rent, Utilities)
  vendorId       String? // Who was paid?

  amount   Decimal       @db.Decimal(18, 2)
  currency String        @default("NGN")
  status   InvoiceStatus @default(DRAFT)

  // --- FORTRESS TRACEABILITY ---
  // FIXED: Removed 'transactionId String?' here because Transaction model 
  // now holds 'expenseId'. Prisma only allows the ID on one side for 1:1.

  approvalId String? @unique // Linked to an ApprovalRequest if > threshold
  reference  String? // Invoice # or Receipt #

  date          DateTime @default(now())
  attachmentUrl String? // Digital proof (Receipt image)

  createdById String
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  branch       Branch       @relation(fields: [branchId], references: [id])
  category     Category     @relation(fields: [categoryId], references: [id])
  vendor       Vendor?      @relation(fields: [vendorId], references: [id])

  createdBy AuthorizedPersonnel  @relation("ExpenseCreatedBy", fields: [createdById], references: [id])
  updatedBy AuthorizedPersonnel? @relation("ExpenseUpdatedBy", fields: [updatedById], references: [id])

  // FIXED: Simply points back to the named relation defined in Transaction
  transaction Transaction? @relation("TransactionToExpense")

  approval ApprovalRequest? @relation(fields: [approvalId], references: [id])

  @@index([organizationId, status])
  @@index([branchId])
}

model ReconciliationLog {
  id String @id @default(cuid())

  // --- PREMIUM UPGRADES: Added multi-tenant consistency ---
  organizationId String
  branchId       String?

  accountId   String
  personnelId String

  statementDate DateTime
  ledgerBalance Decimal  @db.Decimal(18, 2)
  actualBalance Decimal  @db.Decimal(18, 2)
  discrepancy   Decimal  @db.Decimal(18, 2)

  status String
  notes  String?

  createdAt DateTime            @default(now())
  account   FinanceAccount      @relation(fields: [accountId], references: [id])
  personnel AuthorizedPersonnel @relation(fields: [personnelId], references: [id])

  @@index([organizationId])
  @@index([branchId])
  @@index([accountId])
}

////////////////////////////////////
// CUSTOMER ORDER SUMMARIES
////////////////////////////////////

model CustomerOrderSummary {
  id                String    @id @default(cuid())
  organizationId    String
  branchId          String
  customerId        String
  totalOrders       Int       @default(0)
  totalQuantity     Int       @default(0)
  totalSpent        Decimal   @default(0) @db.Decimal(18, 2)
  averageOrderValue Decimal?  @db.Decimal(18, 2)
  lifetimeValue     Decimal?  @db.Decimal(18, 2)
  lastOrderAt       DateTime?
  productBreakdown  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([organizationId, branchId, customerId])
  @@index([organizationId])
  @@index([branchId])
  @@index([customerId])
}

////////////////////////////////////
// NEXTAUTH HELPERS
////////////////////////////////////

model AuthAccount {
  id                String  @id @default(cuid())
  personnelId       String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  personnel AuthorizedPersonnel @relation(fields: [personnelId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([personnelId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  personnelId  String
  expires      DateTime

  personnel AuthorizedPersonnel @relation(fields: [personnelId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([personnelId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
