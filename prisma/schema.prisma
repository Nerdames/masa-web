////////////////////////////////////
// GENERATOR & DATASOURCE
////////////////////////////////////

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

////////////////////////////////////
// ENUMS
////////////////////////////////////

enum Role {
  ADMIN
  MANAGER
  SALES
  INVENTORY
  CASHIER
  DEV
}

enum CustomerType {
  BUYER
  SUPPLIER
}

enum OrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
  RETURNED
}

enum StockMovementType {
  IN
  OUT
  ADJUST
  TRANSFER
}

enum ProductTag {
  DISCONTINUED
  OUT_OF_STOCK
  LOW_STOCK
  HOT
}

enum NotificationType {
  INFO
  WARNING
  ERROR
  SYSTEM
}

////////////////////////////////////
// ORGANIZATION & BRANCHES
////////////////////////////////////

model Organization {
  id     String  @id @default(cuid())
  name   String
  active Boolean @default(true)

  ownerId String?
  owner   AuthorizedPersonnel? @relation("OrgOwner", fields: [ownerId], references: [id])

  personnel         AuthorizedPersonnel[]
  branches          Branch[]
  products          Product[]
  customers         Customer[]
  orders            Order[]
  categories        Category[]
  suppliers         Supplier[]
  sales             Sale[]
  notifications     Notification[]
  activityLogs      ActivityLog[]
  branchProducts    BranchProduct[]
  customerTags      CustomerTag[]
  customerGroups    CustomerGroup[]
  customerSummaries CustomerOrderSummary[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model Branch {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  location       String?
  active         Boolean   @default(true)
  deletedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  personnel         AuthorizedPersonnel[]
  branchProducts    BranchProduct[]
  stockMoves        StockMovement[]        @relation("BranchStockMoves")
  orders            Order[]
  activityLogs      ActivityLog[]
  notifications     Notification[]
  branchAssignments BranchAssignment[]     @relation("BranchAssignments")
  customerSummaries CustomerOrderSummary[]
}

////////////////////////////////////
// AUTHORIZED PERSONNEL
////////////////////////////////////

model AuthorizedPersonnel {
  id        String    @id @default(cuid())
  name      String?
  email     String    @unique
  password  String
  staffCode String?   @unique
  disabled  Boolean   @default(false)
  deletedAt DateTime?
  lastLogin DateTime?

  organizationId String
  branchId       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  branch       Branch?      @relation(fields: [branchId], references: [id])

  branchAssignments BranchAssignment[]
  orders            Order[]
  activityLogs      ActivityLog[]
  notifications     Notification[]
  stockMoves        StockMovement[]
  accounts          Account[]
  sessions          Session[]

  ownedOrganizations Organization[] @relation("OrgOwner")

  // BACK-RELATIONS FOR SALES
  salesAttended Sale[] @relation("AttendantSales")
}

model BranchAssignment {
  id          String @id @default(cuid())
  personnelId String
  branchId    String
  role        Role

  personnel AuthorizedPersonnel @relation(fields: [personnelId], references: [id])
  branch    Branch              @relation("BranchAssignments", fields: [branchId], references: [id])
}

////////////////////////////////////
// CUSTOMERS
////////////////////////////////////

model Customer {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  email          String?
  phone          String?
  address        String?      
  type           CustomerType

  totalOrders Int       @default(0)
  totalSpent  Float     @default(0)
  deletedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization      Organization           @relation(fields: [organizationId], references: [id])
  orders            Order[]
  tags              CustomerTag[]
  groups            CustomerGroup[]        @relation("CustomerGroups")
  customerSummaries CustomerOrderSummary[]

  sales Sale[] @relation("CustomerSales")
}

model CustomerTag {
  id             String @id @default(cuid())
  organizationId String
  customerId     String
  name           String

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])
}

model CustomerGroup {
  id             String  @id @default(cuid())
  organizationId String
  name           String
  description    String?

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  customers    Customer[]   @relation("CustomerGroups")
}

////////////////////////////////////
// PRODUCTS & INVENTORY
////////////////////////////////////

model Product {
  id             String  @id @default(cuid())
  organizationId String
  name           String
  sku            String  @unique
  barcode        String? @unique
  description    String?

  categoryId String?
  costPrice  Float
  currency   String  @default("NGN")

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  category     Category?    @relation(fields: [categoryId], references: [id])

  branches   BranchProduct[]
  orderItems OrderItem[]     @relation("ProductOrderItems")
  sales      Sale[]          @relation("ProductSales")
}

model BranchProduct {
  id             String @id @default(cuid())
  organizationId String
  branchId       String
  productId      String

  stock           Int        @default(0)
  reorderLevel    Int        @default(0)
  tag             ProductTag @default(LOW_STOCK)
  lastSoldAt      DateTime?  
  lastRestockedAt DateTime?  
  safetyStock     Int?       @default(0)
  unit            String?    @default("pcs")
  sellingPrice    Float
  supplierId      String?
  costPrice       Float?

  organization Organization @relation(fields: [organizationId], references: [id])
  branch       Branch       @relation(fields: [branchId], references: [id])
  product      Product      @relation(fields: [productId], references: [id])
  supplier     Supplier?    @relation(fields: [supplierId], references: [id])

  orderItems OrderItem[]     @relation("BranchProductOrderItems")
  sales      Sale[]          @relation("BranchProductSales")
  stockMoves StockMovement[] @relation("BranchProductStockMoves")

  @@unique([branchId, productId])
  @@index([organizationId])
  @@index([branchId])
  @@index([productId])
  @@index([supplierId])
}

model Category {
  id             String  @id @default(cuid())
  organizationId String
  name           String
  description    String?

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  products     Product[]
}

model Supplier {
  id             String  @id @default(cuid())
  organizationId String
  name           String
  email          String?
  phone          String?
  address        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id])
  branchProducts BranchProduct[]
}

////////////////////////////////////
// ORDERS, ORDER ITEMS & INVOICES
////////////////////////////////////

model Order {
  id             String  @id @default(cuid())
  organizationId String
  branchId       String
  personnelId    String
  customerId     String?

  total      Float
  paidAmount Float       @default(0)
  balance    Float       @default(0)
  currency   String      @default("NGN")
  status     OrderStatus @default(PENDING)
  dueDate    DateTime?   
  paymentTerms String?   
  notes      String?     
  deletedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id])
  branch       Branch              @relation(fields: [branchId], references: [id])
  personnel    AuthorizedPersonnel @relation(fields: [personnelId], references: [id])
  customer     Customer?           @relation(fields: [customerId], references: [id])

  items    OrderItem[]
  invoices Invoice[]
}

model OrderItem {
  id              String @id @default(cuid())
  orderId         String
  branchProductId String
  productId       String
  quantity        Int
  price           Float
  total           Float
  discount        Float? @default(0)
  tax             Float? @default(0)

  order         Order         @relation(fields: [orderId], references: [id])
  branchProduct BranchProduct @relation("BranchProductOrderItems", fields: [branchProductId], references: [id])
  product       Product       @relation("ProductOrderItems", fields: [productId], references: [id])

  @@index([orderId])
  @@index([branchProductId])
  @@index([productId])
}

model Invoice {
  id        String   @id @default(cuid())
  orderId   String
  total     Float
  paid      Boolean  @default(false)
  currency  String   @default("NGN")
  discount  Float?   @default(0)
  tax       Float?   @default(0)
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])
}

////////////////////////////////////
// SALES
////////////////////////////////////

model Sale {
  id              String   @id @default(cuid())
  organizationId  String
  branchProductId String
  productId       String
  quantity        Int
  total           Float
  currency        String   @default("NGN")
  createdAt       DateTime @default(now())

  attendantId String?  
  customerId  String?  
  paymentType String?  
  discount    Float? @default(0)
  tax         Float? @default(0)

  organization  Organization  @relation(fields: [organizationId], references: [id])
  branchProduct BranchProduct @relation("BranchProductSales", fields: [branchProductId], references: [id])
  product       Product       @relation("ProductSales", fields: [productId], references: [id])

  attendant AuthorizedPersonnel? @relation("AttendantSales", fields: [attendantId], references: [id])
  customer  Customer?            @relation("CustomerSales", fields: [customerId], references: [id])

  @@index([organizationId])
  @@index([branchProductId])
  @@index([productId])
  @@index([createdAt])
}

////////////////////////////////////
// STOCK MOVEMENTS
////////////////////////////////////

model StockMovement {
  id              String            @id @default(cuid())
  branchProductId String
  branchId        String?
  personnelId     String?
  type            StockMovementType
  quantity        Int
  note            String?
  sourceBranchId  String? 
  targetBranchId  String? 

  createdAt DateTime @default(now())

  branchProduct BranchProduct        @relation("BranchProductStockMoves", fields: [branchProductId], references: [id])
  branch        Branch?              @relation("BranchStockMoves", fields: [branchId], references: [id])
  personnel     AuthorizedPersonnel? @relation(fields: [personnelId], references: [id])

  @@index([branchProductId])
  @@index([branchId])
  @@index([personnelId])
  @@index([type])
  @@index([createdAt])
}

////////////////////////////////////
// NOTIFICATIONS
////////////////////////////////////

model Notification {
  id             String  @id @default(cuid())
  organizationId String
  branchId       String?
  personnelId    String?

  type    NotificationType @default(INFO)
  title   String
  message String
  read    Boolean          @default(false)
  readBy  Json?            // array of personnelIds

  createdAt DateTime @default(now())

  organization Organization         @relation(fields: [organizationId], references: [id])
  branch       Branch?              @relation(fields: [branchId], references: [id])
  personnel    AuthorizedPersonnel? @relation(fields: [personnelId], references: [id])
}

////////////////////////////////////
// ACTIVITY LOG
////////////////////////////////////

model ActivityLog {
  id             String  @id @default(cuid())
  organizationId String
  branchId       String?
  personnelId    String?

  action String
  meta   String?

  createdAt DateTime @default(now())

  organization Organization         @relation(fields: [organizationId], references: [id])
  branch       Branch?              @relation(fields: [branchId], references: [id])
  personnel    AuthorizedPersonnel? @relation(fields: [personnelId], references: [id])
}

////////////////////////////////////
// CUSTOMER ORDER SUMMARY (REPORTING)
////////////////////////////////////

model CustomerOrderSummary {
  id               String    @id @default(cuid())
  organizationId   String
  branchId         String
  customerId       String
  totalOrders      Int
  totalQuantity    Int
  totalSpent       Float
  currency         String    @default("NGN")
  lastOrderAt      DateTime?
  productBreakdown Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

////////////////////////////////////
// NEXTAUTH
////////////////////////////////////

model Account {
  id                String @id @default(cuid())
  personnelId       String
  type              String
  provider          String
  providerAccountId String

  refresh_token String?
  access_token  String?
  expires_at    Int?
  token_type    String?
  scope         String?
  id_token      String?
  session_state String?

  personnel AuthorizedPersonnel @relation(fields: [personnelId], references: [id])

  @@unique([provider, providerAccountId])
  @@index([personnelId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  personnelId  String
  expires      DateTime

  personnel AuthorizedPersonnel @relation(fields: [personnelId], references: [id])

  @@index([personnelId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
