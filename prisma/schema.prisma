////////////////////////////////////
// GENERATOR & DATASOURCE
////////////////////////////////////

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

////////////////////////////////////
// ENUMS
////////////////////////////////////

enum Role {
  ADMIN
  MANAGER
  SALES
  INVENTORY
  CASHIER
  DEV
}

enum CustomerType {
  BUYER
  SUPPLIER
}

enum OrderStatus {
  DRAFT
  SUBMITTED
  FULFILLED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  VOIDED
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  MOBILE_MONEY
  POS
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum StockMovementType {
  IN
  OUT
  ADJUST
  TRANSFER
}

enum NotificationType {
  INFO
  WARNING
  ERROR
  SYSTEM
}

enum SaleStatus {
  COMPLETED
  CANCELLED
}

enum PreferenceScope {
  USER
  BRANCH
  ORGANIZATION
}

enum PreferenceCategory {
  UI
  LAYOUT
  TABLE
  NOTIFICATION
  SYSTEM
}

////////////////////////////////////
// ORGANIZATION & BRANCH
////////////////////////////////////

model Organization {
  id     String  @id @default(cuid())
  name   String
  active Boolean @default(true)

  ownerId String?
  owner   AuthorizedPersonnel? @relation("OrgOwner", fields: [ownerId], references: [id])

  personnel         AuthorizedPersonnel[]
  branches          Branch[]
  products          Product[]
  customers         Customer[]
  orders            Order[]
  invoices          Invoice[]
  sales             Sale[]
  notifications     Notification[]
  activityLogs      ActivityLog[]
  branchProducts    BranchProduct[]
  customerTags      CustomerTag[]
  customerGroups    CustomerGroup[]
  customerSummaries CustomerOrderSummary[]
  receipts          Receipt[]
  preferences       Preference[]

  categories Category[]
  suppliers  Supplier[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model Branch {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  location       String?
  active         Boolean   @default(true)
  deletedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  personnel         AuthorizedPersonnel[]
  branchProducts    BranchProduct[]
  stockMoves        StockMovement[]        @relation("BranchStockMoves")
  orders            Order[]
  invoices          Invoice[]
  sales             Sale[] // Branch → Sale
  activityLogs      ActivityLog[]
  notifications     Notification[]
  branchAssignments BranchAssignment[]     @relation("BranchAssignments")
  customerSummaries CustomerOrderSummary[]
  receipts          Receipt[]
  preferences       Preference[]

  @@index([organizationId])
}

////////////////////////////////////
// AUTHORIZED PERSONNEL
////////////////////////////////////

model AuthorizedPersonnel {
  id        String    @id @default(cuid())
  name      String?
  email     String    @unique
  password  String
  staffCode String?   @unique
  disabled  Boolean   @default(false)
  deletedAt DateTime?
  lastLogin DateTime?

  organizationId String
  branchId       String?

  isOrgOwner Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  branch       Branch?      @relation(fields: [branchId], references: [id])

  branchAssignments  BranchAssignment[]
  orders             Order[]            @relation("SalespersonOrders")
  invoicesIssued     Invoice[]          @relation("IssuedInvoices")
  invoicesPaid       Payment[]          @relation("InvoicePaidBy")
  salesAttended      Sale[]             @relation("AttendantSales")
  activityLogs       ActivityLog[]
  notifications      Notification[]
  stockMoves         StockMovement[]
  accounts           Account[]
  sessions           Session[]
  ownedOrganizations Organization[]     @relation("OrgOwner")
  receipts           Receipt[]
  preferences        Preference[]
}

model BranchAssignment {
  id          String @id @default(cuid())
  personnelId String
  branchId    String
  role        Role

  personnel AuthorizedPersonnel @relation(fields: [personnelId], references: [id])
  branch    Branch              @relation("BranchAssignments", fields: [branchId], references: [id])

  @@index([personnelId])
  @@index([branchId])
}

////////////////////////////////////
// CUSTOMERS
////////////////////////////////////

model Customer {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  email          String?
  phone          String?
  address        String?
  type           CustomerType

  totalOrders Int       @default(0)
  totalSpent  Float     @default(0)
  deletedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization      Organization           @relation(fields: [organizationId], references: [id])
  orders            Order[]
  invoices          Invoice[]
  sales             Sale[]                 @relation("CustomerSales")
  tags              CustomerTag[]
  groups            CustomerGroup[]        @relation("CustomerGroups")
  customerSummaries CustomerOrderSummary[]
}

model CustomerTag {
  id             String @id @default(cuid())
  organizationId String
  customerId     String
  name           String

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])

  @@index([organizationId])
  @@index([customerId])
}

model CustomerGroup {
  id             String  @id @default(cuid())
  organizationId String
  name           String
  description    String?

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  customers    Customer[]   @relation("CustomerGroups")

  @@index([organizationId])
}

////////////////////////////////////
// PRODUCTS & INVENTORY
////////////////////////////////////

model Product {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  sku            String    @unique
  barcode        String?   @unique
  description    String?
  categoryId     String?
  costPrice      Float
  currency       String    @default("NGN")
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  category     Category?    @relation(fields: [categoryId], references: [id])

  branches   BranchProduct[]
  orderItems OrderItem[]     @relation("ProductOrderItems")
  sales      Sale[]          @relation("ProductSales")

  @@index([organizationId])
  @@index([categoryId])
}

model BranchProduct {
  id             String @id @default(cuid())
  organizationId String
  branchId       String
  productId      String

  stock           Int       @default(0)
  reorderLevel    Int       @default(0)
  lastSoldAt      DateTime?
  lastRestockedAt DateTime?
  safetyStock     Int?      @default(0)
  unit            String?   @default("pcs")
  sellingPrice    Float
  supplierId      String?
  costPrice       Float?

  organization Organization @relation(fields: [organizationId], references: [id])
  branch       Branch       @relation(fields: [branchId], references: [id])
  product      Product      @relation(fields: [productId], references: [id])
  supplier     Supplier?    @relation(fields: [supplierId], references: [id])

  orderItems OrderItem[]     @relation("BranchProductOrderItems")
  sales      Sale[]          @relation("BranchProductSales")
  stockMoves StockMovement[] @relation("BranchProductStockMoves")
  receipts   Receipt[]

  @@unique([branchId, productId])
  @@index([organizationId])
  @@index([branchId])
  @@index([productId])
  @@index([supplierId])
}

model Category {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  products     Product[]

  @@index([organizationId])
}

model Supplier {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  email          String?
  phone          String?
  address        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id])
  branchProducts BranchProduct[]

  @@index([organizationId])
}

////////////////////////////////////
// ORDERS, ORDER ITEMS, INVOICES
////////////////////////////////////

model Order {
  id             String  @id @default(cuid())
  organizationId String
  branchId       String
  salespersonId  String
  customerId     String?

  total     Float
  currency  String      @default("NGN")
  status    OrderStatus @default(DRAFT)
  notes     String?
  expiresAt DateTime?
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items      OrderItem[]
  invoice    Invoice?
  invoicedAt DateTime?

  organization Organization        @relation(fields: [organizationId], references: [id])
  branch       Branch              @relation(fields: [branchId], references: [id])
  salesperson  AuthorizedPersonnel @relation("SalespersonOrders", fields: [salespersonId], references: [id])
  customer     Customer?           @relation(fields: [customerId], references: [id])

  @@index([organizationId, branchId, status])
}

model OrderItem {
  id              String @id @default(cuid())
  orderId         String
  branchProductId String
  productId       String

  quantity  Int
  unitPrice Float
  total     Float
  discount  Float? @default(0)
  tax       Float? @default(0)

  order         Order         @relation(fields: [orderId], references: [id])
  branchProduct BranchProduct @relation("BranchProductOrderItems", fields: [branchProductId], references: [id])
  product       Product       @relation("ProductOrderItems", fields: [productId], references: [id])

  @@index([orderId])
  @@index([branchProductId])
  @@index([productId])
}

model Invoice {
  id             String @id @default(cuid())
  organizationId String
  branchId       String
  orderId        String @unique

  issuedById String
  customerId String?

  subtotal   Float?
  total      Float
  discount   Float?        @default(0)
  tax        Float?        @default(0)
  paidAmount Float         @default(0)
  balance    Float
  currency   String        @default("NGN")
  status     InvoiceStatus @default(DRAFT)
  deletedAt  DateTime?

  issuedAt DateTime  @default(now())
  dueDate  DateTime?
  lockedAt DateTime?

  payments Payment[]
  sales    Sale[]
  receipts Receipt[]

  organization Organization        @relation(fields: [organizationId], references: [id])
  branch       Branch              @relation(fields: [branchId], references: [id])
  order        Order               @relation(fields: [orderId], references: [id])
  issuedBy     AuthorizedPersonnel @relation("IssuedInvoices", fields: [issuedById], references: [id])
  customer     Customer?           @relation(fields: [customerId], references: [id])
  checkHash    String?

  @@index([organizationId, branchId, status])
  @@index([issuedAt])
}

model Payment {
  id        String @id @default(cuid())
  invoiceId String
  cashierId String

  method    PaymentMethod
  amount    Float
  currency  String        @default("NGN")
  status    PaymentStatus @default(COMPLETED)
  deletedAt DateTime?

  reference  String?
  receivedAt DateTime @default(now())

  invoice Invoice             @relation(fields: [invoiceId], references: [id])
  cashier AuthorizedPersonnel @relation("InvoicePaidBy", fields: [cashierId], references: [id])

  // One-to-one optional relation with Receipt
  receipt Receipt?

  @@index([invoiceId])
  @@index([method])
  @@index([status])
  @@index([receivedAt])
}

model Sale {
  id              String @id @default(cuid())
  organizationId  String
  invoiceId       String
  branchProductId String
  productId       String
  branchId        String

  quantity  Int
  unitPrice Float
  total     Float
  currency  String     @default("NGN")
  status    SaleStatus @default(COMPLETED)
  deletedAt DateTime?

  cashierId  String
  customerId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @default(now())

  organization  Organization        @relation(fields: [organizationId], references: [id])
  invoice       Invoice             @relation(fields: [invoiceId], references: [id])
  branchProduct BranchProduct       @relation("BranchProductSales", fields: [branchProductId], references: [id])
  product       Product             @relation("ProductSales", fields: [productId], references: [id])
  cashier       AuthorizedPersonnel @relation("AttendantSales", fields: [cashierId], references: [id])
  customer      Customer?           @relation("CustomerSales", fields: [customerId], references: [id])
  branch        Branch              @relation(fields: [branchId], references: [id])
  receipts      Receipt[]

  @@index([invoiceId])
  @@index([organizationId, branchId])
  @@index([createdAt])
}

model Receipt {
  id              String        @id @default(cuid())
  saleId          String        @unique
  cashierId       String
  branchId        String
  branchProductId String
  organizationId  String
  invoiceId       String
  amount          Float
  paymentMethod   PaymentMethod
  currency        String        @default("NGN")
  createdAt       DateTime      @default(now())

  paymentId String? @unique

  sale          Sale                @relation(fields: [saleId], references: [id])
  cashier       AuthorizedPersonnel @relation(fields: [cashierId], references: [id])
  branch        Branch              @relation(fields: [branchId], references: [id])
  branchProduct BranchProduct       @relation(fields: [branchProductId], references: [id])
  organization  Organization        @relation(fields: [organizationId], references: [id])
  invoice       Invoice             @relation(fields: [invoiceId], references: [id])
  payment       Payment?            @relation(fields: [paymentId], references: [id])

  @@index([invoiceId])
  @@index([paymentId])
}

////////////////////////////////////
// STOCK MOVEMENTS
////////////////////////////////////

model StockMovement {
  id              String            @id @default(cuid())
  branchProductId String
  personnelId     String
  branchId        String
  type            StockMovementType
  quantity        Int
  referenceId     String?

  createdAt DateTime @default(now())

  branchProduct BranchProduct       @relation("BranchProductStockMoves", fields: [branchProductId], references: [id])
  branch        Branch              @relation("BranchStockMoves", fields: [branchId], references: [id])
  personnel     AuthorizedPersonnel @relation(fields: [personnelId], references: [id])

  @@index([branchProductId])
  @@index([referenceId])
}

////////////////////////////////////
// NOTIFICATIONS
////////////////////////////////////

model Notification {
  id             String  @id @default(cuid())
  organizationId String
  branchId       String?
  personnelId    String?

  type    NotificationType @default(INFO)
  title   String
  message String
  read    Boolean          @default(false)
  readBy  Json?

  createdAt DateTime @default(now())

  organization Organization         @relation(fields: [organizationId], references: [id])
  branch       Branch?              @relation(fields: [branchId], references: [id])
  personnel    AuthorizedPersonnel? @relation(fields: [personnelId], references: [id])

  @@index([organizationId])
  @@index([branchId])
  @@index([personnelId])
}

////////////////////////////////////
// ACTIVITY LOG
////////////////////////////////////

model ActivityLog {
  id             String  @id @default(cuid())
  organizationId String
  branchId       String?
  personnelId    String?

  action String
  meta   String?

  createdAt DateTime @default(now())

  organization Organization         @relation(fields: [organizationId], references: [id])
  branch       Branch?              @relation(fields: [branchId], references: [id])
  personnel    AuthorizedPersonnel? @relation(fields: [personnelId], references: [id])

  @@index([organizationId])
  @@index([branchId])
  @@index([personnelId])
}

////////////////////////////////////
// CUSTOMER ORDER SUMMARY
////////////////////////////////////

model CustomerOrderSummary {
  id               String    @id @default(cuid())
  organizationId   String
  branchId         String
  customerId       String
  totalOrders      Int
  totalQuantity    Int
  totalSpent       Float
  currency         String    @default("NGN")
  lastOrderAt      DateTime?
  productBreakdown Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([branchId])
  @@index([customerId])
}

////////////////////////////////////
// NEXTAUTH
////////////////////////////////////

model Account {
  id                String @id @default(cuid())
  personnelId       String
  type              String
  provider          String
  providerAccountId String

  refresh_token String?
  access_token  String?
  expires_at    Int?
  token_type    String?
  scope         String?
  id_token      String?
  session_state String?

  personnel AuthorizedPersonnel @relation(fields: [personnelId], references: [id])

  @@unique([provider, providerAccountId])
  @@index([personnelId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  personnelId  String
  expires      DateTime

  personnel AuthorizedPersonnel @relation(fields: [personnelId], references: [id])

  @@index([personnelId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Preference {
  id             String  @id @default(cuid())
  organizationId String
  branchId       String?
  personnelId    String?

  scope    PreferenceScope
  category PreferenceCategory
  key      String
  value    Json
  target   String?   // <-- NEW optional column for page/component/feature

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch?              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  personnel    AuthorizedPersonnel? @relation(fields: [personnelId], references: [id], onDelete: Cascade)

  @@unique([scope, key, organizationId, branchId, personnelId, target])
  @@index([organizationId])
  @@index([branchId])
  @@index([personnelId])
  @@index([scope])
  @@index([category])
  @@index([target])
}

