////////////////////////////////////
// GENERATOR & DATASOURCE
////////////////////////////////////

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

////////////////////////////////////
// ENUMS
////////////////////////////////////

enum Role {
  ADMIN
  MANAGER
  SALES
  INVENTORY
  CASHIER
  DEV
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum CriticalAction {
  EMAIL_CHANGE
  PASSWORD_CHANGE
  PRICE_UPDATE
  STOCK_ADJUST
  STOCK_TRANSFER
  VOID_INVOICE
  USER_LOCK_UNLOCK
}

enum CustomerType {
  BUYER
  PARTNER
}

enum OrderStatus {
  DRAFT
  SUBMITTED
  FULFILLED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  VOIDED
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  MOBILE_MONEY
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum AccountType {
  CASH
  BANK
  MOBILE
  POS
}

enum StockMovementType {
  IN
  OUT
  ADJUST
  TRANSFER
}

enum StockTransferStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ExpenseType {
  OPERATIONAL
  CAPITAL
  MISC
}

enum NotificationType {
  INFO
  WARNING
  ERROR
  SYSTEM
  APPROVAL_REQUIRED
  APPROVAL_DECISION
}

enum SaleStatus {
  COMPLETED
  CANCELLED
}

enum DraftSaleStatus {
  OPEN
  CHECKOUT
  ABANDONED
}

enum PreferenceScope {
  USER
  BRANCH
  ORGANIZATION
}

enum PreferenceCategory {
  UI
  LAYOUT
  TABLE
  NOTIFICATION
  SYSTEM
}

////////////////////////////////////
// ORGANIZATION & BRANCH
////////////////////////////////////

model Organization {
  id     String  @id @default(cuid())
  name   String
  active Boolean @default(true)

  ownerId String?
  owner   AuthorizedPersonnel? @relation("OrgOwner", fields: [ownerId], references: [id])

  approvalRequests ApprovalRequest[] @relation("OrgApprovals")

  financeAccounts      FinanceAccount[]
  personnel            AuthorizedPersonnel[]  @relation("OrgMembers")
  branches             Branch[]
  products             Product[]
  customers            Customer[]
  orders               Order[]
  invoices             Invoice[]
  sales                Sale[]
  notifications        Notification[]
  activityLogs         ActivityLog[]
  branchProducts       BranchProduct[]
  customerTags         CustomerTag[]
  customerGroups       CustomerGroup[]
  customerSummaries    CustomerOrderSummary[]
  receipts             Receipt[]
  preferences          Preference[]
  notificationSettings NotificationSetting[]
  stockMovements       StockMovement[]

  categories     Category[]
  vendors        Vendor[]
  expenses       Expense[]
  draftSales     DraftSale[]     @relation("OrgDraftSales")
  stockTransfers StockTransfer[] @relation("OrgStockTransfers")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model Branch {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  location       String?
  active         Boolean   @default(true)
  deletedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id])
  approvalRequests ApprovalRequest[] @relation("BranchApprovals")

  financeAccounts   FinanceAccount[]
  personnel         AuthorizedPersonnel[]
  branchProducts    BranchProduct[]
  stockMoves        StockMovement[]        @relation("BranchStockMoves")
  orders            Order[]
  invoices          Invoice[]
  sales             Sale[]
  activityLogs      ActivityLog[]
  notifications     Notification[]
  branchAssignments BranchAssignment[]     @relation("BranchAssignments")
  customerSummaries CustomerOrderSummary[]
  receipts          Receipt[]
  preferences       Preference[]
  draftSales        DraftSale[]            @relation("BranchDraftSales")
  transfersFrom     StockTransfer[]        @relation("BranchTransfersFrom")
  transfersTo       StockTransfer[]        @relation("BranchTransfersTo")
  expenses          Expense[]

  @@index([organizationId])
}

////////////////////////////////////
// AUTHORIZED PERSONNEL
////////////////////////////////////

model AuthorizedPersonnel {
  id        String    @id @default(cuid())
  name      String?
  email     String
  password  String
  staffCode String?   @unique
  disabled  Boolean   @default(false)
  deletedAt DateTime?
  lastLogin DateTime?

  organizationId String
  branchId       String?

  isOrgOwner Boolean @default(false)

  pendingEmail    String?
  pendingPassword String?
  isLocked        Boolean @default(false)
  lockReason      String?

  failedLoginAttempts Int       @default(0)
  lockoutUntil        DateTime?
  lastActivityAt      DateTime?

  lastLoginIp     String?
  lastLoginDevice String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requestsCreated  ApprovalRequest[] @relation("Requester")
  requestsApproved ApprovalRequest[] @relation("Approver")
  authAccounts     AuthAccount[]

  organization Organization @relation("OrgMembers", fields: [organizationId], references: [id])
  branch       Branch?      @relation(fields: [branchId], references: [id])

  branchAssignments      BranchAssignment[]
  orders                 Order[]                 @relation("SalespersonOrders")
  invoicesIssued         Invoice[]               @relation("IssuedInvoices")
  invoicesPaid           Payment[]               @relation("InvoicePaidBy")
  salesAttended          Sale[]                  @relation("AttendantSales")
  activityLogs           ActivityLog[]
  stockMoves             StockMovement[]
  financeAccounts        FinanceAccount[]
  sessions               Session[]
  ownedOrganizations     Organization[]          @relation("OrgOwner")
  receipts               Receipt[]               @relation("PersonnelReceipts")
  preferences            Preference[]
  notificationRecipients NotificationRecipient[]
  notificationSettings   NotificationSetting[]
  draftSales             DraftSale[]             @relation("CashierDraftSales")
  createdStockTransfers  StockTransfer[]         @relation("CreatedStockTransfers")
  approvedStockTransfers StockTransfer[]         @relation("ApprovedStockTransfers")

  @@unique([organizationId, email])
  @@index([branchId])
  @@index([lastLogin])
  @@index([lastActivityAt])
  @@index([failedLoginAttempts])
  @@index([lockoutUntil])
  @@index([isLocked])
}

////////////////////////////////////
// APPROVAL SYSTEM
////////////////////////////////////

model ApprovalRequest {
  id             String  @id @default(cuid())
  organizationId String
  branchId       String?
  branch         Branch? @relation("BranchApprovals", fields: [branchId], references: [id])
  requesterId    String
  approverId     String?

  actionType    CriticalAction
  status        ApprovalStatus @default(PENDING)
  requiredRole  Role           @default(MANAGER)
  changes       Json
  rejectionNote String?

  targetType String?
  targetId   String?

  expiresAt DateTime?
  appliedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  organization Organization         @relation("OrgApprovals", fields: [organizationId], references: [id])
  requester    AuthorizedPersonnel  @relation("Requester", fields: [requesterId], references: [id])
  approver     AuthorizedPersonnel? @relation("Approver", fields: [approverId], references: [id])

  stockMovements StockMovement[] @relation("ApprovalStockMoves")
  activityLogs   ActivityLog[]   @relation("ApprovalLogs")

  @@index([organizationId, status])
  @@index([branchId, status])
  @@index([actionType])
}

model BranchAssignment {
  id          String @id @default(cuid())
  personnelId String
  branchId    String
  role        Role

  personnel AuthorizedPersonnel @relation(fields: [personnelId], references: [id])
  branch    Branch              @relation("BranchAssignments", fields: [branchId], references: [id])

  @@unique([personnelId, branchId])
  @@index([personnelId])
  @@index([branchId])
}

////////////////////////////////////
// CUSTOMERS
////////////////////////////////////

model Customer {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  email          String?
  phone          String?
  address        String?
  type           CustomerType

  totalOrders Int       @default(0)
  totalSpent  Float     @default(0)
  deletedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization      Organization           @relation(fields: [organizationId], references: [id])
  orders            Order[]
  invoices          Invoice[]
  sales             Sale[]                 @relation("CustomerSales")
  tags              CustomerTag[]
  groups            CustomerGroup[]        @relation("CustomerGroups")
  customerSummaries CustomerOrderSummary[]
}

model CustomerTag {
  id             String    @id @default(cuid())
  organizationId String
  customerId     String
  name           String
  deletedAt      DateTime?

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])

  @@index([organizationId])
  @@index([customerId])
}

model CustomerGroup {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  description    String?
  deletedAt      DateTime?

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  customers    Customer[]   @relation("CustomerGroups")

  @@index([organizationId])
}

////////////////////////////////////
// PRODUCTS & INVENTORY
////////////////////////////////////

model Product {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  sku            String
  barcode        String?
  description    String?
  categoryId     String?
  costPrice      Decimal   @db.Decimal(18, 2)
  currency       String    @default("NGN")
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  category     Category?    @relation(fields: [categoryId], references: [id])

  branches           BranchProduct[]
  orderItems         OrderItem[]         @relation("ProductOrderItems")
  sales              Sale[]              @relation("ProductSales")
  draftSaleItems     DraftSaleItem[]
  stockTransferItems StockTransferItem[]
  stockMovements     StockMovement[]

  @@unique([organizationId, sku])
  @@unique([organizationId, barcode])
  @@index([organizationId])
  @@index([categoryId])
}

model BranchProduct {
  id             String @id @default(cuid())
  organizationId String
  branchId       String
  productId      String

  stock           Int       @default(0)
  stockVersion    Int       @default(1)
  reorderLevel    Int       @default(0)
  lastSoldAt      DateTime?
  lastRestockedAt DateTime?
  safetyStock     Int?      @default(0)
  unit            String?   @default("pcs")
  sellingPrice    Decimal?  @db.Decimal(18, 2)
  vendorId        String?
  costPrice       Decimal?  @db.Decimal(18, 2)
  deletedAt       DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  vendor       Vendor?      @relation(fields: [vendorId], references: [id])

  orderItems         OrderItem[]         @relation("BranchProductOrderItems")
  sales              Sale[]              @relation("BranchProductSales")
  stockMoves         StockMovement[]     @relation("BranchProductStockMoves")
  receipts           Receipt[]
  draftSaleItems     DraftSaleItem[]
  stockTransferItems StockTransferItem[]

  @@unique([branchId, productId])
  @@index([organizationId])
  @@index([branchId])
  @@index([productId])
  @@index([vendorId])
  @@index([stock])
  @@index([reorderLevel])
  @@index([deletedAt])
}

////////////////////////////////////
// CATEGORIES, VENDORS & ORDERS
////////////////////////////////////

model Category {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  description    String?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  products     Product[]
  expenses     Expense[]

  @@index([organizationId])
}

model Vendor {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  email          String?
  phone          String?
  address        String?
  deletedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id])
  branchProducts BranchProduct[]
  expenses       Expense[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([organizationId, deletedAt])
}

////////////////////////////////////
// ORDERS & INVOICES
////////////////////////////////////

model Order {
  id             String  @id @default(cuid())
  organizationId String
  branchId       String
  salespersonId  String
  customerId     String?

  total     Decimal     @db.Decimal(18, 2)
  currency  String      @default("NGN")
  status    OrderStatus @default(DRAFT)
  notes     String?
  expiresAt DateTime?
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items      OrderItem[]
  invoice    Invoice?
  invoicedAt DateTime?

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  salesperson  AuthorizedPersonnel @relation("SalespersonOrders", fields: [salespersonId], references: [id])
  customer     Customer?           @relation(fields: [customerId], references: [id])

  @@index([organizationId, branchId, status])
  @@index([organizationId, deletedAt])
  @@index([branchId, createdAt])
}

model OrderItem {
  id              String @id @default(cuid())
  organizationId  String
  orderId         String
  branchProductId String
  productId       String

  quantity  Int
  unitPrice Decimal  @db.Decimal(18, 2)
  total     Decimal  @db.Decimal(18, 2)
  discount  Decimal? @default(0) @db.Decimal(18, 2)
  tax       Decimal? @default(0) @db.Decimal(18, 2)

  order         Order         @relation(fields: [orderId], references: [id])
  branchProduct BranchProduct @relation("BranchProductOrderItems", fields: [branchProductId], references: [id])
  product       Product       @relation("ProductOrderItems", fields: [productId], references: [id])

  @@index([orderId])
  @@index([branchProductId])
  @@index([productId])
}

model Invoice {
  id             String @id @default(cuid())
  organizationId String
  branchId       String
  orderId        String @unique

  issuedById String
  customerId String?

  subtotal   Decimal?      @db.Decimal(18, 2)
  total      Decimal?      @db.Decimal(18, 2)
  discount   Decimal?      @default(0) @db.Decimal(18, 2)
  tax        Decimal?      @default(0) @db.Decimal(18, 2)
  paidAmount Decimal?      @default(0) @db.Decimal(18, 2)
  balance    Decimal?      @db.Decimal(18, 2)
  currency   String        @default("NGN")
  status     InvoiceStatus @default(DRAFT)
  deletedAt  DateTime?

  issuedAt DateTime  @default(now())
  dueDate  DateTime?
  lockedAt DateTime?

  payments Payment[]
  sales    Sale[]
  receipts Receipt[]

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch              @relation(fields: [branchId], references: [id])
  order        Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  issuedBy     AuthorizedPersonnel @relation("IssuedInvoices", fields: [issuedById], references: [id])
  customer     Customer?           @relation(fields: [customerId], references: [id])
  checkHash    String?

  @@index([organizationId, branchId, status])
  @@index([issuedAt])
  @@index([organizationId, deletedAt])
}

model Payment {
  id             String  @id @default(cuid())
  organizationId String
  invoiceId      String
  cashierId      String
  receiptId      String?

  method    PaymentMethod
  amount    Decimal       @db.Decimal(18, 2)
  currency  String        @default("NGN")
  status    PaymentStatus @default(COMPLETED)
  deletedAt DateTime?

  reference  String?
  receivedAt DateTime @default(now())

  invoice Invoice             @relation(fields: [invoiceId], references: [id])
  cashier AuthorizedPersonnel @relation("InvoicePaidBy", fields: [cashierId], references: [id])
  receipt Receipt?            @relation("PaymentReceipt", fields: [receiptId], references: [id])

  @@index([invoiceId])
  @@index([method])
  @@index([status])
  @@index([receivedAt])
  @@index([currency])
  @@index([reference])
}

////////////////////////////////////
// DRAFT SALES & SALES
////////////////////////////////////

model DraftSale {
  id             String @id @default(cuid())
  organizationId String
  branchId       String
  cashierId      String

  status    DraftSaleStatus @default(OPEN)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items DraftSaleItem[]

  organization Organization        @relation("OrgDraftSales", fields: [organizationId], references: [id])
  branch       Branch              @relation("BranchDraftSales", fields: [branchId], references: [id])
  cashier      AuthorizedPersonnel @relation("CashierDraftSales", fields: [cashierId], references: [id])
}

model DraftSaleItem {
  id              String @id @default(cuid())
  organizationId  String
  draftSaleId     String
  branchProductId String
  productId       String

  quantity  Int
  unitPrice Decimal @db.Decimal(18, 2)

  draftSale     DraftSale     @relation(fields: [draftSaleId], references: [id])
  branchProduct BranchProduct @relation(fields: [branchProductId], references: [id])
  product       Product       @relation(fields: [productId], references: [id])
}

model Sale {
  id              String @id @default(cuid())
  organizationId  String
  invoiceId       String
  branchProductId String
  productId       String
  branchId        String

  quantity  Int
  unitPrice Decimal    @db.Decimal(18, 2)
  total     Decimal    @db.Decimal(18, 2)
  currency  String     @default("NGN")
  status    SaleStatus @default(COMPLETED)
  deletedAt DateTime?

  cashierId  String
  customerId String?
  receipts   Receipt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization  Organization        @relation(fields: [organizationId], references: [id])
  invoice       Invoice             @relation(fields: [invoiceId], references: [id])
  branchProduct BranchProduct       @relation("BranchProductSales", fields: [branchProductId], references: [id])
  product       Product             @relation("ProductSales", fields: [productId], references: [id])
  branch        Branch              @relation(fields: [branchId], references: [id])
  attendant     AuthorizedPersonnel @relation("AttendantSales", fields: [cashierId], references: [id])
  customer      Customer?           @relation("CustomerSales", fields: [customerId], references: [id])

  @@index([organizationId, branchId])
  @@index([invoiceId])
  @@index([productId])
  @@index([branchProductId])
  @@index([cashierId])
  @@index([customerId])
}

////////////////////////////////////
// STOCK MOVEMENTS
////////////////////////////////////

model StockMovement {
  id              String            @id @default(cuid())
  organizationId  String
  branchId        String
  branchProductId String
  productId       String
  type            StockMovementType
  quantity        Int
  unitCost        Decimal           @db.Decimal(18, 2)
  totalCost       Decimal           @db.Decimal(18, 2)
  approvedAt      DateTime?
  approvalId      String?
  reason          String?
  deletedAt       DateTime?
  handledById     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization  Organization         @relation(fields: [organizationId], references: [id])
  branch        Branch               @relation("BranchStockMoves", fields: [branchId], references: [id])
  branchProduct BranchProduct        @relation("BranchProductStockMoves", fields: [branchProductId], references: [id])
  product       Product              @relation(fields: [productId], references: [id])
  approval      ApprovalRequest?     @relation("ApprovalStockMoves", fields: [approvalId], references: [id])
  handledBy     AuthorizedPersonnel? @relation(fields: [handledById], references: [id])

  @@index([organizationId])
  @@index([branchId])
  @@index([branchProductId])
  @@index([productId])
  @@index([type])
  @@index([approvedAt])
  @@index([deletedAt])
}

////////////////////////////////////
// RECEIPTS & TRANSACTIONS
////////////////////////////////////

model Receipt {
  id              String  @id @default(cuid())
  organizationId  String
  branchId        String
  personnelId     String
  saleId          String?
  invoiceId       String?
  branchProductId String?

  amount    Decimal   @db.Decimal(18, 2)
  currency  String    @default("NGN")
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization  Organization         @relation(fields: [organizationId], references: [id])
  branch        Branch               @relation(fields: [branchId], references: [id])
  personnel     AuthorizedPersonnel? @relation("PersonnelReceipts", fields: [personnelId], references: [id])
  sale          Sale?                @relation(fields: [saleId], references: [id])
  invoice       Invoice?             @relation(fields: [invoiceId], references: [id])
  branchProduct BranchProduct?       @relation(fields: [branchProductId], references: [id])
  payments      Payment[]            @relation("PaymentReceipt")

  @@index([organizationId, branchId])
  @@index([saleId])
  @@index([invoiceId])
  @@index([branchProductId])
  @@index([deletedAt])
}

////////////////////////////////////
// ACTIVITY LOGS
////////////////////////////////////

model ActivityLog {
  id             String    @id @default(cuid())
  organizationId String
  branchId       String?
  personnelId    String?
  action         String
  critical       Boolean   @default(false)
  ipAddress      String?
  deviceInfo     String?
  metadata       Json?
  deletedAt      DateTime?
  approvalId     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id])
  branch       Branch?              @relation(fields: [branchId], references: [id])
  personnel    AuthorizedPersonnel? @relation(fields: [personnelId], references: [id])
  approval     ApprovalRequest?     @relation("ApprovalLogs", fields: [approvalId], references: [id])

  @@index([organizationId, branchId])
  @@index([personnelId])
  @@index([action])
  @@index([critical])
  @@index([createdAt])
  @@index([deletedAt])
}

////////////////////////////////////
// NOTIFICATIONS
////////////////////////////////////

model Notification {
  id             String           @id @default(cuid())
  organizationId String
  branchId       String?
  type           NotificationType
  title          String
  message        String
  read           Boolean          @default(false)
  deletedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization            @relation(fields: [organizationId], references: [id])
  branch       Branch?                 @relation(fields: [branchId], references: [id])
  recipients   NotificationRecipient[]

  @@index([organizationId, branchId])
  @@index([type])
  @@index([read])
  @@index([deletedAt])
}

model NotificationRecipient {
  id             String  @id @default(cuid())
  notificationId String
  personnelId    String
  read           Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notification Notification        @relation(fields: [notificationId], references: [id])
  personnel    AuthorizedPersonnel @relation(fields: [personnelId], references: [id])

  @@unique([notificationId, personnelId])
  @@index([personnelId])
  @@index([read])
}

model NotificationSetting {
  id               String           @id @default(cuid())
  organizationId   String
  personnelId      String?
  notificationType NotificationType
  enabled          Boolean          @default(true)
  deletedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id])
  personnel    AuthorizedPersonnel? @relation(fields: [personnelId], references: [id])

  @@unique([organizationId, personnelId, notificationType])
  @@index([organizationId])
  @@index([personnelId])
}

////////////////////////////////////
// PREFERENCES
////////////////////////////////////

model Preference {
  id             String             @id @default(cuid())
  scope          PreferenceScope
  category       PreferenceCategory
  key            String
  value          Json
  organizationId String
  branchId       String?
  personnelId    String?
  target         String?
  isLocked       Boolean            @default(false)
  deletedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id])
  branch       Branch?              @relation(fields: [branchId], references: [id])
  personnel    AuthorizedPersonnel? @relation(fields: [personnelId], references: [id])

  @@unique([scope, category, key, organizationId, branchId, personnelId, target])
  @@index([organizationId])
  @@index([branchId])
  @@index([personnelId])
  @@index([scope])
  @@index([category])
  @@index([key])
  @@index([target])
  @@index([deletedAt])
}

////////////////////////////////////
// ACCOUNTS & TRANSACTIONS
////////////////////////////////////

model FinanceAccount {
  id             String      @id @default(cuid())
  organizationId String
  branchId       String?
  personnelId    String?
  name           String
  balance        Decimal     @default(0) @db.Decimal(18, 2)
  currency       String      @default("NGN")
  type           AccountType
  deletedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id])
  branch       Branch?              @relation(fields: [branchId], references: [id])
  personnel    AuthorizedPersonnel? @relation(fields: [personnelId], references: [id])

  transactions Transaction[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([branchId])
  @@index([personnelId])
  @@index([deletedAt])
}

model Transaction {
  id        String  @id @default(cuid())
  accountId String
  type      String
  amount    Decimal @db.Decimal(18, 2)
  currency  String  @default("NGN")
  metadata  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account FinanceAccount @relation(fields: [accountId], references: [id])

  @@index([accountId])
  @@index([type])
  @@index([createdAt])
}

////////////////////////////////////
// EXPENSES
////////////////////////////////////

model Expense {
  id             String      @id @default(cuid())
  organizationId String
  branchId       String?
  vendorId       String?
  type           ExpenseType
  categoryId     String?
  amount         Decimal     @db.Decimal(18, 2)
  currency       String      @default("NGN")
  description    String?
  paidAt         DateTime?
  deletedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  branch       Branch?      @relation(fields: [branchId], references: [id])
  vendor       Vendor?      @relation(fields: [vendorId], references: [id])
  category     Category?    @relation(fields: [categoryId], references: [id])

  @@index([organizationId, branchId])
  @@index([vendorId])
  @@index([categoryId])
  @@index([deletedAt])
}

////////////////////////////////////
// CUSTOMER ORDER SUMMARIES
////////////////////////////////////

model CustomerOrderSummary {
  id                String    @id @default(cuid())
  organizationId    String
  branchId          String
  customerId        String
  totalOrders       Int       @default(0)
  totalQuantity     Int       @default(0)
  totalSpent        Decimal   @default(0) @db.Decimal(18, 2)
  averageOrderValue Decimal?  @db.Decimal(18, 2)
  lifetimeValue     Decimal?  @db.Decimal(18, 2)
  lastOrderAt       DateTime?
  productBreakdown  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([branchId])
  @@index([customerId])
}

////////////////////////////////////
// STOCK TRANSFERS
////////////////////////////////////

model StockTransfer {
  id             String              @id @default(cuid())
  organizationId String
  fromBranchId   String
  toBranchId     String
  status         StockTransferStatus
  createdById    String
  approvedById   String?
  approvedAt     DateTime?
  deletedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization         @relation("OrgStockTransfers", fields: [organizationId], references: [id])
  fromBranch   Branch               @relation("BranchTransfersFrom", fields: [fromBranchId], references: [id])
  toBranch     Branch               @relation("BranchTransfersTo", fields: [toBranchId], references: [id])
  createdBy    AuthorizedPersonnel  @relation("CreatedStockTransfers", fields: [createdById], references: [id])
  approvedBy   AuthorizedPersonnel? @relation("ApprovedStockTransfers", fields: [approvedById], references: [id])

  items StockTransferItem[]

  @@index([organizationId])
  @@index([fromBranchId])
  @@index([toBranchId])
  @@index([status])
  @@index([deletedAt])
}

model StockTransferItem {
  id              String    @id @default(cuid())
  stockTransferId String
  branchProductId String
  productId       String
  quantity        Int
  deletedAt       DateTime?

  stockTransfer StockTransfer @relation(fields: [stockTransferId], references: [id])
  branchProduct BranchProduct @relation(fields: [branchProductId], references: [id])
  product       Product       @relation(fields: [productId], references: [id])

  @@index([stockTransferId])
  @@index([branchProductId])
  @@index([productId])
}

////////////////////////////////////
// NEXTAUTH HELPERS
////////////////////////////////////

model AuthAccount {
  id                String  @id @default(cuid())
  personnelId       String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  personnel AuthorizedPersonnel @relation(fields: [personnelId], references: [id])

  @@unique([provider, providerAccountId])
  @@index([personnelId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  personnelId  String
  expires      DateTime

  personnel AuthorizedPersonnel @relation(fields: [personnelId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([personnelId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
